---
const services = [
  {
    img: "/sec_camera.jpg",
    src: "/servicios/cctv",
    alt: "Instalación de cámaras de seguridad y CCTV en Cartagena y Barranquilla",
    title: "CCTV y cámaras de seguridad",
    sub: "Instalación y mantenimiento de sistemas CCTV para empresas, edificios y hogares."
  },
  {
    img: "https://img.freepik.com/free-photo/man-getting-intercom-read-his-fingerprint-open-door-with-gloves_176474-2789.jpg",
    src: "/servicios/control-acceso",
    alt: "Instalación de sistemas de control de acceso en Cartagena y Barranquilla",
    title: "Sistemas de control de acceso",
    sub: "Control de acceso biométrico, tarjetas y soluciones electrónicas seguras."
  },
  {
    img: "/network.jpg",
    src: "/servicios/cableado-estructurado",
    alt: "Instalación de cableado estructurado en Cartagena y Barranquilla",
    title: "Cableado estructurado",
    sub: "Diseño e instalación de redes de datos confiables y escalables."
  },
  {
    img: "https://img.freepik.com/free-photo/smoke-alarm-isolated-white_93675-132063.jpg",
    src: "/servicios/deteccion-incendios",
    alt: "Instalación de sistemas de detección de incendios en Cartagena y Barranquilla",
    title: "Detección de incendios",
    sub: "Sistemas de detección y alarma contra incendios conforme a normativa."
  }
];
---

<section
  id="servicios"
  class="w-full py-12 md:py-24 lg:py-32 bg-muted"
>
  <div class="container mx-auto px-4 md:px-6">
    <div class="flex flex-col items-center justify-center space-y-4 text-center">
      <div class="space-y-2">
        <div
          data-aos="fade-down"
          class="inline-block rounded-lg bg-main uppercase text-white font-heading px-3 py-1 text-lg"
        >
          Nuestros servicios
        </div>

        <h2
          data-aos="fade-up"
          class="text-4xl font-heading font-bold sm:text-7xl"
        >
          Servicios de seguridad electrónica en Cartagena y Barranquilla
        </h2>

        <p
          data-aos="fade-up"
          class="font-body md:text-xl/relaxed lg:text-base/relaxed xl:text-xl/relaxed"
        >
          En RCISAS ofrecemos soluciones profesionales de CCTV, cámaras de seguridad,
          control de acceso, cableado estructurado y sistemas de detección de incendios
          para empresas y proyectos residenciales en Cartagena y Barranquilla.
        </p>
      </div>
    </div>

    <div
      class="mx-auto grid gap-6 py-12 md:grid-cols-4 md:gap-12"
      data-aos="fade-up"
    >
      {
        services.map((service) => (
          <div class="flex flex-col items-center space-y-4">
            <div class="overflow-hidden rounded-lg">
              <img
                src={service.img}
                alt={service.alt}
                loading="lazy"
                width="300"
                height="300"
                decoding="async"
                class="aspect-square object-cover transition-all hover:scale-105"
              />
            </div>

            <div class="space-y-2 text-center">
              <h3 class="text-lg lg:text-2xl font-bold font-heading">
                <a href={service.src}>
                  {service.title}
                </a>
              </h3>
              <p class="font-body">
                {service.sub}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
