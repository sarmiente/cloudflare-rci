---
import { Image } from "astro:assets"
---

<section class="w-full py-12 md:py-24 lg:py-32 xl:py-48">
  <div class="container mx-auto px-4 md:px-6">
    <div class="grid gap-6 lg:grid-cols-2 lg:gap-12 xl:grid-cols-2">
      <div class="flex flex-col justify-center space-y-4">
        <div class="space-y-2">
          <h1 class="text-4xl font-heading font-bold sm:text-5xl xl:text-6xl/none">
            Soluciones de CCTV, control de acceso y seguridad electrónica en Cartagena y Barranquilla
          </h1>

          <p class="max-w-[600px] font-body md:text-xl">
            Protegemos empresas, edificios y proyectos residenciales con cámaras de seguridad,
            sistemas CCTV, control de acceso y soluciones de conectividad profesional en la región Caribe.
          </p>
        </div>

        <div class="flex flex-col gap-3 min-[400px]:flex-row">
          <button class="bg-main p-2 rounded-lg hover:scale-105 transition">
            <a href="" class="text-white font-medium font-body">
              Agendar consulta técnica
            </a>
          </button>
          <button>
            <a href="#servicios" class="text-third font-body">
              Conocer servicios
            </a>
          </button>
        </div>
      </div>

      <div class="justify-self-center col-span-1 row-span-1">
        <Image
          src="https://images.unsplash.com/photo-1528312635006-8ea0bc49ec63"
          width={550}
          height={550}
          alt="Sistema de cámaras de seguridad y CCTV para empresas en Cartagena y Barranquilla"
          class="rounded-lg object-cover"
          priority
        />
      </div>
    </div>
  </div>
</section>
