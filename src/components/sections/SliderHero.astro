---
import Left from "../../icons/leftarrow.svg";
import Right from "../../icons/rightarrow.svg";
import Chulito from "../../icons/chulito.svg";

const heroImages = [
  {
    src: "https://images.unsplash.com/photo-1676630656246-3047520adfdf?q=80&w=1158&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
    alt: "Security surveillance system"
  },
  {
    src: "https://images.unsplash.com/photo-1710745969844-22350d267b08?q=80&w=687&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
    alt: "Security control room monitoring"
  },
  {
    src: "https://images.unsplash.com/photo-1754494977436-a5c202306fe4?auto=format&fit=crop&w=1080&q=80",
    alt: "Modern security building entrance"
  },
  {
    src: "https://images.unsplash.com/photo-1558002038-1055907df827?auto=format&fit=crop&w=1080&q=80",
    alt: "Home security system smart"
  },
  {
    src: "https://images.unsplash.com/photo-1668097613572-40b7c11c8727?q=80&w=1470&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
    alt: "Security technology digital"
  }
];

---

<section class="relative h-screen flex items-center bg-gradient-to-br from-slate-900 to-slate-800 overflow-hidden">

  <!-- Background Images -->
  <div class="absolute inset-0">
    {heroImages.map((image, index) => (
      <div
        class="absolute inset-0 transition-opacity duration-1000 opacity-0"
        data-slide={index}
      >
        <img 
          src={image.src} 
          alt={image.alt ?? 'Sistemas de seguridad electrónica en Cartagena y Barranquilla'} 
          class="w-full h-full object-cover" 
        />
      </div>
    ))}
  </div>

  <!-- Overlays -->
  <div class="absolute inset-0 bg-main/40"></div>
  <div class="absolute inset-0 bg-gradient-to-r from-main/90 to-second/50"></div>

  <!-- Content -->
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 pt-52 lg:pt-48">
    <div class="max-w-4xl">

      <!-- H1 PRINCIPAL (SEO LOCAL) -->
      <h1 
        data-aos="fade-right"
        class="text-white font-heading text-2xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight"
      >
        Empresa de Seguridad Electrónica en Cartagena y Barranquilla
      </h1>

      <!-- H2 DE APOYO SEMÁNTICO -->
      <h2 
        data-aos="fade-right" 
        class="text-white md:text-2xl lg:text-3xl font-heading md:font-medium mb-4"
      >
        Sistemas profesionales de CCTV, control de acceso y conectividad segura
      </h2>

      <!-- TEXTO DESCRIPTIVO LOCAL -->
      <p 
        data-aos="fade-right" 
        class="md:text-xl text-white mb-6 leading-relaxed font-body"
      >
        En RCI SAS instalamos soluciones modernas de seguridad electrónica para empresas y proyectos
        en Cartagena, Barranquilla y la Costa Caribe. Implementamos CCTV, control de acceso,
        cableado estructurado y sistemas de detección de incendios con altos estándares técnicos.
      </p>

      <!-- CTA -->
      <div data-aos="fade-up" class="flex flex-col sm:flex-row gap-4 mb-6">
        <a
          href="https://api.whatsapp.com/send/?phone=573136775143&text=Hola%2C%20estoy%20interesado%20en%20sus%20servicios%20de%20seguridad%20en%20Cartagena%20o%20Barranquilla"
          target="_blank"
          class="inline-flex items-center bg-third hover:bg-third/60 text-white px-5 py-3 font-heading font-bold rounded-xl hover:scale-105 transition"
        >
          Agenda una visita técnica
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="h-4 w-4 ml-2 transition-transform duration-300 group-hover:translate-x-1.5"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
          </svg>
        </a>
      </div>

      <!-- TRUST SIGNALS -->
      <div data-aos="fade-up" class="grid grid-cols-1 sm:grid-cols-3 gap-4 font-body text-sm">
        <div class="flex items-center gap-3">
          <Chulito class="w-5 h-5" />
          <span class="text-gray-200">Personal técnico certificado en Colombia</span>
        </div>
        <div class="flex items-center gap-3">
          <Chulito class="w-5 h-5" />
          <span class="text-gray-200">Soluciones para empresas y proyectos</span>
        </div>
        <div class="flex items-center gap-3">
          <Chulito class="w-5 h-5" />
          <span class="text-gray-200">Equipos y productos certificados</span>
        </div>
      </div>

    </div>
  </div>
</section>


<script is:inline>

  document.addEventListener("DOMContentLoaded", () => {
      let currentIndex = 0;
  const slides = document.querySelectorAll("[data-slide]");
  const indicators = document.querySelectorAll("[data-indicator]");

  function showSlide(index) {
    slides.forEach((slide, i) => {
      slide.classList.toggle("opacity-100", i === index);
      slide.classList.toggle("opacity-0", i !== index);
    });
    indicators.forEach((ind, i) => {
      ind.classList.toggle("bg-white", i === index);
      ind.classList.toggle("scale-125", i === index);
      ind.classList.toggle("bg-white/50", i !== index);
    });
    currentIndex = index;
  }

  document.getElementById("prevSlide")?.addEventListener("click", () => {
    const newIndex = currentIndex === 0 ? slides.length - 1 : currentIndex - 1;
    showSlide(newIndex);
  });

  document.getElementById("nextSlide")?.addEventListener("click", () => {
    const newIndex = currentIndex === slides.length - 1 ? 0 : currentIndex + 1;
    showSlide(newIndex);
  });

  indicators.forEach((btn, i) => {
    btn.addEventListener("click", () => showSlide(i));
  });

  setInterval(() => {
    const newIndex = currentIndex === slides.length - 1 ? 0 : currentIndex + 1;
    showSlide(newIndex);
  }, 5000);

  showSlide(0);
  })

</script>
