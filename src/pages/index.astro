import Layout from '../layouts/Layout.astro';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_IMAGE } from '@/consts';
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION} image={SITE_IMAGE}>
